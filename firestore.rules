rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if ownsUserDoc(userId);
    }

    match /pageVisits/{visitId} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    match /uiEvents/{eventId} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    // Contact form submissions — anyone can create, signed-in users can read/update/delete
    match /contactSubmissions/{submissionId} {
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.email is string &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 2000;
      allow read, delete: if signedIn();
      // Allow admin to update the read flag
      allow update: if signedIn();
    }

    // meta/resumeDownloads — public read, public increment-only update
    match /meta/resumeDownloads {
      allow read: if true;
      allow create: if true;
      allow update: if
        request.resource.data.keys().hasOnly(['count']) &&
        request.resource.data.count == resource.data.count + 1;
    }

    // meta/siteConfig — public read, signed-in write (admin sets resumeUrl etc.)
    match /meta/siteConfig {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
