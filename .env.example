# Copy this file to .env and fill in local values.
# Never commit .env or Firebase service account secrets.

# Frontend API URL. Leave blank for same-origin /api in production.
VITE_API_URL=http://localhost:4000/api

# Firebase browser config.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend auth.
ADMIN_USER_ID=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
JWT_SECRET=optional-legacy-jwt-secret
JWT_EXPIRES_IN=8h

# Firebase Admin. Prefer one of these in deployed environments.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional job search provider.
JSEARCH_API_KEY=
REMOTIVE_BASE_URL=https://remotive.com/api/remote-jobs

# Optional contact email delivery.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=
