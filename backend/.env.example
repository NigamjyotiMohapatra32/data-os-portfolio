# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_EXPIRES_IN=8h

# Single-user credentials (this portfolio is yours only)
# Generate hash: node -e "const b=require('bcryptjs');b.hash('YourPassword',12).then(console.log)"
ADMIN_USER_ID=Nigamjyoti
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# ─── Supabase (use SERVICE ROLE key server-side — never expose to browser) ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Job Search ───────────────────────────────────────────────────────────────
# Remotive is public — no key needed. Add others if you get API access.
REMOTIVE_BASE_URL=https://remotive.com/api/remote-jobs
JSEARCH_API_KEY=           # RapidAPI JSearch (optional, 500 free/month)

# ─── Email (Contact Form) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nigamjob32@gmail.com
SMTP_PASS=your-gmail-app-password
CONTACT_TO=nigamjob32@gmail.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-portfolio.vercel.app
